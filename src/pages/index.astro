---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import FilterTabs from '../components/FilterTabs.astro';

const blogPosts = (await getCollection('projects')).map((post) => ({
  ...post,
  _type: 'projects'
}));
const ctfPosts = (await getCollection('ctf')).map((post) => ({
  ...post,
  _type: 'ctf'
}));
const bugbountyPosts = (await getCollection('bugbounty')).map((post) => ({
  ...post,
  _type: 'bugbounty'
}));

const allPosts = [...blogPosts, ...ctfPosts, ...bugbountyPosts]
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = ['All', 'CTF', 'Bug Bounty', 'Projects'];
---

<BaseLayout title="Home" description="Security research blog - CTF writeups and bug bounty findings" showHero={true} customHead={`<meta name="google-site-verification" content="V7ey-CBS45MB1F1wnw0Mca_V55A3HIY2MVsvFtrgeYk" />`}>
  <section>
    <FilterTabs categories={categories} defaultCategory="all" />
    
    <div class="grid gap-4" id="posts-grid">
      {allPosts.map((post) => {
        let url = '/';
        if (post._type === 'ctf') {
          url = `/ctf/${post.id}`;
        } else if (post._type === 'bugbounty') {
          url = `/bugbounty/${post.id}`;
        } else if (post._type === 'projects') {
          url = `/projects/${post.id}`;
        }

const platform = post._type === 'ctf' ? (post.data as any).ctfPlatform : undefined;
const difficulty = post._type === 'ctf' ? (post.data as any).difficulty : undefined;

return (
  <PostCard
    title={post.data.title}
    description={post.data.description}
    pubDate={post.data.pubDate}
    url={url}
    category={post._type}
    platform={platform}
    difficulty={difficulty}
    tags={post.data.tags}
  />
);
      })}
    </div>

    {allPosts.length === 0 && (
      <div class="text-center py-16">
        <p class="text-text-muted">No posts yet</p>
      </div>
    )}
  </section>
</BaseLayout>