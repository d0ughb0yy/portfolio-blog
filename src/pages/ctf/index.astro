---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import FilterTabs from '../../components/FilterTabs.astro';

const allPosts = await getCollection('ctf', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const allTags = posts.flatMap((post) => post.data.tags || []);
const allPlatforms = [...new Set(posts.map((post) => post.data.ctfPlatform).filter(Boolean))];
const allDifficulties = [...new Set(posts.map((post) => post.data.difficulty).filter(Boolean))];
---

<BaseLayout title="CTF Writeups" description="CTF writeups and walkthroughs">
  <section>
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-text-primary mb-2 font-mono">CTF Writeups</h1>
      <p class="text-text-secondary">{posts.length} writeup{posts.length !== 1 ? 's' : ''}</p>
    </div>

    <FilterTabs tags={allPlatforms} />

    <div class="grid gap-4" id="posts-grid">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          url={`/ctf/${post.id}`}
          category="ctf"
          platform={post.data.ctfPlatform}
          difficulty={post.data.difficulty}
          tags={[...(post.data.difficulty ? [post.data.difficulty] : []), ...(post.data.tags || [])]}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-16">
        <p class="text-text-muted">No posts</p>
      </div>
    )}
  </section>
</BaseLayout>