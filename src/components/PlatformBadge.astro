---
interface Props {
  platform: string;
}

const platformColors: Record<string, string> = {
  HackTheBox: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  VulnHub: 'bg-orange-500/20 text-orange-400 border-orange-500/30',
  TryHackMe: 'bg-red-500/20 text-red-400 border-red-500/30',
  PicoCTF: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  CTFtime: 'bg-green-500/20 text-green-400 border-green-500/30',
  Other: 'bg-gray-500/20 text-gray-400 border-gray-500/30',
};

const colorClass = platformColors[Astro.props.platform] || platformColors.Other;
---

<span class={`text-xs font-mono px-2 py-1 rounded border ${colorClass}`}>
	{Astro.props.platform}
</span>