---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';

const blogPosts = (await getCollection('blog')).map((post) => ({
  ...post,
  _type: 'blog'
}));
const ctfPosts = (await getCollection('ctf')).map((post) => ({
  ...post,
  _type: 'ctf'
}));
const bugbountyPosts = (await getCollection('bugbounty')).map((post) => ({
  ...post,
  _type: 'bugbounty'
}));

const allPosts = [...blogPosts, ...ctfPosts, ...bugbountyPosts]
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const latestPosts = allPosts;
---

<BaseLayout title="Home" description="Security research blog - CTF writeups and bug bounty findings">
  <div class="mb-12">
    <h1 class="text-3xl font-bold text-text-primary mb-8">Security Blog</h1>
    <p class="text-text-secondary mb-8">
      A collection of CTF writeups, bug bounty findings, and security research.
    </p>

    <div class="grid gap-6">
      {latestPosts.map((post) => {
        let url = '/';
        if (post._type === 'ctf') {
          url = `/ctf/${post.id}`;
        } else if (post._type === 'bugbounty') {
          url = `/bugbounty/${post.id}`;
        } else if (post._type === 'blog') {
          url = `/blog/${post.id}`;
        }

        return (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            url={url}
            platform={post.data.ctfPlatform}
            difficulty={post.data.difficulty}
            tags={post.data.tags}
          />
        );
      })}
    </div>
  </div>
</BaseLayout>