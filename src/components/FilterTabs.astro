---
interface Props {
  categories?: string[];
  tags?: string[];
  defaultCategory?: string;
}

const { categories = [], tags = [], defaultCategory = 'all' } = Astro.props;
const uniqueTags = [...new Set(tags)].sort();
---

<div class="filter-container mb-8">
  {categories.length > 0 && (
    <div class="flex items-center gap-2 mb-4 flex-wrap">
      <span class="text-text-muted text-sm mr-2">Filter:</span>
      <div class="flex gap-2" id="category-tabs">
        {categories.map((category, index) => (
<button
	class={`category-btn px-4 py-2 rounded text-sm font-medium transition-all duration-200 whitespace-nowrap ${
		(category.toLowerCase().replace(/\s+/g, '') === defaultCategory || (defaultCategory === 'all' && index === 0))
		? 'bg-[rgba(34,197,94,0.1)] text-primary border border-[rgba(34,197,94,0.3)]'
		: 'bg-surface text-text-secondary border border-border hover:border-primary hover:text-primary'
	}`}
	data-category={category.toLowerCase().replace(/\s+/g, '')}
>
            {category}
          </button>
        ))}
      </div>
    </div>
  )}

  {uniqueTags.length > 0 && (
    <div class="flex items-center gap-2 flex-wrap">
      <span class="text-text-muted text-sm mr-2">Filter:</span>
<button
	class="tag-btn px-3 py-1 rounded text-xs font-medium transition-all duration-200 bg-[rgba(34,197,94,0.1)] text-primary border border-[rgba(34,197,94,0.3)]"
	data-tag="all"
>
All
</button>
{uniqueTags.map((tag) => (
	<button
		class="tag-btn px-3 py-1 rounded text-xs font-medium transition-all duration-200 bg-surface text-text-secondary border border-border hover:border-primary hover:text-primary"
		data-tag={tag}
	>
		{tag}
	</button>
))}
    </div>
  )}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const categoryBtns = document.querySelectorAll('.category-btn');
    const tagBtns = document.querySelectorAll('.tag-btn');
    const postCards = document.querySelectorAll('.post-card');

    let activeCategory = 'all';
    let activeTag = 'all';

    function filterPosts() {
      postCards.forEach((card) => {
        const cardCategory = card.getAttribute('data-category');
        const cardTags = card.getAttribute('data-tags')?.split(',') || [];
        
        const categoryMatch = activeCategory === 'all' || cardCategory === activeCategory;
        const tagMatch = activeTag === 'all' || cardTags.includes(activeTag);

        if (categoryMatch && tagMatch) {
          card.style.display = 'block';
          card.classList.add('animate-fade-in');
        } else {
          card.style.display = 'none';
        }
      });

      updateActiveButtons();
    }

function updateActiveButtons() {
	categoryBtns.forEach((btn) => {
		const btnCategory = btn.getAttribute('data-category');
		if (btnCategory === activeCategory) {
			btn.classList.remove('bg-surface', 'text-text-secondary', 'border-border');
			btn.classList.add('bg-[rgba(34,197,94,0.1)]', 'text-primary', 'border-[rgba(34,197,94,0.3)]');
		} else {
			btn.classList.remove('bg-[rgba(34,197,94,0.1)]', 'text-primary', 'border-[rgba(34,197,94,0.3)]');
			btn.classList.add('bg-surface', 'text-text-secondary', 'border-border');
		}
	});

	tagBtns.forEach((btn) => {
		const btnTag = btn.getAttribute('data-tag');
		if (btnTag === activeTag) {
			btn.classList.remove('bg-surface', 'text-text-secondary', 'border-border');
			btn.classList.add('bg-[rgba(34,197,94,0.1)]', 'text-primary', 'border-[rgba(34,197,94,0.3)]');
		} else {
			btn.classList.remove('bg-[rgba(34,197,94,0.1)]', 'text-primary', 'border-[rgba(34,197,94,0.3)]');
			btn.classList.add('bg-surface', 'text-text-secondary', 'border-border');
		}
	});
}

    categoryBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCategory = btn.getAttribute('data-category') || 'all';
        filterPosts();
      });
    });

    tagBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        activeTag = btn.getAttribute('data-tag') || 'all';
        filterPosts();
      });
    });
  });
</script>