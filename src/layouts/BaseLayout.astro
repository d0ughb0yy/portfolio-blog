---
interface Props {
    title: string;
    description?: string;
    showHero?: boolean;
}

const {
    title,
    description = "Security research blog - CTF writeups and bug bounty findings",
    showHero = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | Tin Lučić - Blog</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Archivo:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <script
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-EWDHWHP1BC"
        ></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            window.gtag = function gtag() {
                window.dataLayer.push(arguments);
            };
            gtag("js", new Date());
            gtag("config", "G-EWDHWHP1BC");
        </script>
    </head>
    <body class="min-h-screen bg-background font-sans">
	<div class="bg-grid" aria-hidden="true"></div>
		{showHero && <canvas id="matrix-canvas" aria-hidden="true"></canvas>}

        <nav
            id="navbar"
            class="nav fixed top-0 left-0 right-0 z-50 transition-all duration-200"
            role="navigation"
            aria-label="Main navigation"
        >
            <div
                class="max-w-6xl mx-auto px-6 nav-container flex items-center justify-between h-[72px]"
            >
                <a
                    href="/"
                    class="flex items-center gap-2 font-heading font-bold text-lg tracking-wider text-text-primary"
                    aria-label="Home"
                >
                    <svg
                        width="28"
                        height="28"
                        viewBox="0 0 28 28"
                        fill="none"
                        aria-hidden="true"
                    >
                        <rect
                            x="2"
                            y="2"
                            width="24"
                            height="24"
                            rx="4"
                            stroke="#22c55e"
                            stroke-width="2"></rect>
                        <path
                            d="M8 14l3 3 7-7"
                            stroke="#22c55e"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                    <span class="text-primary">TinL</span>
                </a>

                <ul
                    class="nav-menu hidden xl:flex items-center gap-1 list-none"
                >
                    <li><a href="/" class="nav-link">Home</a></li>
                    <li><a href="/ctf" class="nav-link">CTF</a></li>
                    <li>
                        <a href="/bugbounty" class="nav-link">Bug Bounty</a>
                    </li>
                    <li><a href="/projects" class="nav-link">Projects</a></li>
                    <li>
                        <a
                            href="https://tinl-portfolio.netlify.app"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="nav-link">Portfolio</a
                        >
                    </li>
                </ul>

                <button
                    id="hamburger"
                    class="hamburger xl:hidden"
                    aria-label="Toggle navigation menu"
                    aria-expanded="false"
                >
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                    <span class="hamburger-line"></span>
                </button>
            </div>
        </nav>

        <div
            id="mobile-menu"
            class="fixed right-0 top-0 bottom-0 w-64 bg-[rgba(2,6,23,0.98)] backdrop-blur-xl border-l border-border z-[1001] transform translate-x-full transition-all duration-200 xl:hidden"
        >
            <div class="flex flex-col items-center justify-center h-full gap-3">
                <a href="/" class="nav-link-mobile">Home</a>
                <a href="/ctf" class="nav-link-mobile">CTF</a>
                <a href="/bugbounty" class="nav-link-mobile">Bug Bounty</a>
                <a href="/projects" class="nav-link-mobile">Projects</a>
                <a
                    href="https://tinl-portfolio.netlify.app"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="nav-link-mobile">Portfolio</a
                >
            </div>
        </div>

        {
            showHero && (
                <section
                    id="hero"
                    class="hero min-h-screen flex flex-col items-center justify-center relative overflow-hidden pt-[72px] pb-20"
                >
                    <div class="hero-content relative z-10 text-center max-w-[700px] mx-auto px-6 pb-20">
                        <div class="hero-glow" aria-hidden="true" />

                        <div class="terminal-badge" aria-hidden="true">
                            <svg
                                width="12"
                                height="12"
                                viewBox="0 0 12 12"
                                fill="#22c55e"
                            >
                                <circle cx="6" cy="6" r="6" />
                            </svg>
                            <span class="terminal-status">● ACTIVE</span>
                        </div>

                        <p class="text-sm md:text-base text-text-muted uppercase tracking-[3px] mb-2">
                            Welcome to
                        </p>
                        <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl font-bold mb-4 leading-tight">
                            <span
                                class="typewriter"
                                data-text="The Blog"
                                id="typewriter"
                            />
                        </h1>
                        <p
                            class="text-lg md:text-xl text-primary font-heading mb-6 min-h-[33px]"
                            id="role-rotate"
                        />
                        <p class="text-sm md:text-base text-text-muted max-w-[560px] mx-auto mb-10 leading-relaxed">
                            Web application security researcher and bug bounty
                            hunter with experience in identifying critical
                            vulnerabilities in web applications.
                        </p>

                        <div class="flex gap-4 justify-center flex-wrap">
                            <a href="/ctf" class="btn btn-primary">
                                View Work
                                <svg
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M3 8h10M9 4l4 4-4 4" />
                                </svg>
                            </a>
                            <a
                                href="mailto:tin.lucic172@gmail.com"
                                class="btn btn-ghost"
                            >
                                <svg
                                    viewBox="0 0 16 16"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                >
                                    <path d="M4 4h8M4 8h6M2 12V5a3 3 0 013-3h6a3 3 0 013 3v7" />
                                    <polyline points="4 12 2 12 2 14h8v-2z" />
                                </svg>
                                Get In Touch
                            </a>
                        </div>
                    </div>

                    <a
                        href="#content"
                        class="scroll-indicator absolute bottom-12 left-1/2 -translate-x-1/2 block cursor-pointer"
                        aria-label="Scroll to content"
                    >
                        <div class="w-6 h-6 border-r-2 border-b-2 border-text-dim rotate-45 animate-[scrollBounce_2s_ease-in-out_infinite]" />
                    </a>
                </section>
            )
        }

        <main
            id="content"
            class={`${showHero ? "" : "pt-24"} max-w-6xl w-full mx-auto px-4 md:px-6 py-8`}
        >
            <slot />
        </main>

        <footer class="footer border-t border-border mt-16">
            <div
                class="max-w-6xl mx-auto px-6 py-8 footer-inner flex items-center justify-between flex-wrap gap-4"
            >
                <div class="flex items-center gap-4">
                    <a
                        href="/"
                        class="flex items-center gap-2 font-heading font-bold text-lg tracking-wider text-text-primary"
                    >
                        <svg
                            width="24"
                            height="24"
                            viewBox="0 0 28 28"
                            fill="none"
                            aria-hidden="true"
                        >
                            <rect
                                x="2"
                                y="2"
                                width="24"
                                height="24"
                                rx="4"
                                stroke="#22c55e"
                                stroke-width="2"></rect>
                            <path
                                d="M8 14l3 3 7-7"
                                stroke="#22c55e"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                        </svg>
                        <span class="text-primary">TinL</span>
                    </a>
                    <p class="text-xs md:text-sm text-text-dim">
                        &copy; <span id="year"></span> Tin Lučić. All rights reserved.
                    </p>
                </div>
                <nav
                    class="flex gap-6 flex-wrap"
                    aria-label="Footer navigation"
                >
                    <a
                        href="/"
                        class="text-xs md:text-sm text-text-muted hover:text-primary transition-all duration-200"
                        >Home</a
                    >
                    <a
                        href="/ctf"
                        class="text-xs md:text-sm text-text-muted hover:text-primary transition-all duration-200"
                        >CTF</a
                    >
                    <a
                        href="/bugbounty"
                        class="text-xs md:text-sm text-text-muted hover:text-primary transition-all duration-200"
                        >Bug Bounty</a
                    >
                    <a
                        href="/projects"
                        class="text-xs md:text-sm text-text-muted hover:text-primary transition-all duration-200"
                        >Projects</a
                    >
                    <a
                        href="https://tinl-portfolio.netlify.app"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs md:text-sm text-text-muted hover:text-primary transition-all duration-200"
                        >Portfolio</a
                    >
                </nav>
            </div>
        </footer>

        <button
            id="back-to-top"
            class="fixed bottom-6 right-6 z-40 w-12 h-12 bg-[rgba(34,197,94,0.1)] border border-[rgba(34,197,94,0.4)] rounded-full flex items-center justify-center text-primary hover:bg-[rgba(34,197,94,0.2)] hover:border-[rgba(34,197,94,0.7)] hover:shadow-[0_0_20px_rgba(34,197,94,0.4)] transition-all duration-300 opacity-0 invisible translate-y-4"
            aria-label="Back to top"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 15l7-7 7 7"></path>
            </svg>
        </button>

        <dialog
            id="global-image-modal"
            class="backdrop:bg-black/90 p-0 border-0 bg-transparent"
        >
            <img
                id="global-modal-image"
                src=""
                alt=""
                class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg"
            />
            <button
                id="global-modal-close"
                class="absolute top-1 right-1 z-10 w-8 h-8 bg-surface/80 rounded-full flex items-center justify-center text-primary hover:text-primary hover:bg-surface transition-colors"
                aria-label="Close modal"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-4 h-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 6l12 12M18 6l-12 12"></path>
                </svg>
            </button>
        </dialog>

        <style is:global>
            @import "../styles/global.css";

		.nav {
			background: transparent;
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			transition: background 300ms ease, box-shadow 300ms ease;
			box-shadow: none;
		}

		.nav.scrolled {
			background: rgba(2, 6, 23, 0.85);
			box-shadow: inset 0 -1px 0 #334155;
		}

            .nav-link {
                padding: 8px 16px;
                font-size: 14px;
                font-weight: 500;
                color: #94a3b8;
                border-radius: 4px;
                transition: all 200ms ease;
                position: relative;
                text-decoration: none;
            }

            .nav-link:hover,
            .nav-link.active {
                color: #22c55e;
            }

            .nav-link.active::after {
                content: "";
                position: absolute;
                bottom: 2px;
                left: 50%;
                transform: translateX(-50%);
                width: 20px;
                height: 2px;
                background: #22c55e;
                box-shadow: 0 0 8px rgba(34, 197, 94, 0.4);
            }

            .nav-link-mobile {
                padding: 12px 24px;
                font-size: 18px;
                font-weight: 500;
                color: #94a3b8;
                text-decoration: none;
                transition: all 200ms ease;
                width: 100%;
                text-align: center;
            }

            .nav-link-mobile:hover {
                color: #22c55e;
            }

            .hamburger {
                display: none;
                flex-direction: column;
                gap: 5px;
                background: none;
                border: none;
                cursor: pointer;
                padding: 4px;
            }

            .hamburger-line {
                width: 24px;
                height: 2px;
                background: #f8fafc;
                transition: all 200ms ease;
                border-radius: 2px;
            }

            .hamburger.active .hamburger-line:nth-child(1) {
                transform: rotate(45deg) translate(5px, 5px);
            }

            .hamburger.active .hamburger-line:nth-child(2) {
                opacity: 0;
            }

            .hamburger.active .hamburger-line:nth-child(3) {
                transform: rotate(-45deg) translate(5px, -5px);
            }

            body.menu-open {
                overflow: hidden;
            }

            .social-icon {
                color: #94a3b8;
                transition: all 300ms ease;
            }

            .social-icon:hover {
                color: #22c55e;
                transform: scale(1.1);
            }

            dialog::backdrop {
                background: rgba(0, 0, 0, 0.9);
            }

            dialog[open] {
                animation: fadeIn 0.15s ease-out;
            }

            #global-image-modal[open] #global-modal-close {
                position: fixed !important;
                top: 1rem !important;
                right: 1rem !important;
            }

            #matrix-canvas {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                pointer-events: none;
                z-index: 0;
                opacity: 0.15;
            }

            .hero-content {
                position: relative;
                z-index: 1;
            }

            .cursor {
                animation: blink 0.8s step-end infinite;
                color: #22c55e;
                font-weight: 300;
            }

            @media (max-width: 768px) {
                .hamburger {
                    display: flex;
                    z-index: 1001;
                }

                .nav-link-mobile:active {
                    transform: scale(0.98);
                }

                .footer-inner {
                    flex-direction: column;
                    text-align: center;
                }
            }

            @media (max-width: 480px) {
                .hero-actions {
                    flex-direction: column;
                    align-items: center;
                }
            }

            @media (prefers-reduced-motion: reduce) {
                *,
                *::before,
                *::after {
                    animation-duration: 0.01ms !important;
                    animation-iteration-count: 1 !important;
                    transition-duration: 0.01ms !important;
                    scroll-behavior: auto !important;
                }
            }
        </style>

        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const nav = document.getElementById("navbar");
                const hamburger = document.getElementById("hamburger");
                const mobileMenu = document.getElementById("mobile-menu");
                const navLinks = document.querySelectorAll(".nav-link");
                const sections = document.querySelectorAll("section[id]");
                const matrixCanvas = document.getElementById("matrix-canvas");

                function updateActiveSection() {
                    const scrollY = window.scrollY;
                    const offset = (nav?.offsetHeight || 72) + 100;

                    sections.forEach((section, index) => {
                        const sectionTop = section.offsetTop - offset;
                        const sectionHeight = section.offsetHeight;
                        const sectionId = section.getAttribute("id");
                        const isLastSection = index === sections.length - 1;
                        const atBottom =
                            scrollY + window.innerHeight >=
                            document.body.scrollHeight - 50;

                        navLinks.forEach((link) => {
                            link.classList.remove("active");
                            if (isLastSection && atBottom) {
                                if (
                                    link.getAttribute("href") ===
                                    `#${sectionId}`
                                ) {
                                    link.classList.add("active");
                                }
                            } else if (
                                scrollY >= sectionTop &&
                                scrollY < sectionTop + sectionHeight
                            ) {
                                if (
                                    link.getAttribute("href") ===
                                    `#${sectionId}`
                                ) {
                                    link.classList.add("active");
                                }
                            }
                        });
                    });
                }

                function handleNavScroll() {
                    const scrollY = window.scrollY;
                    if (scrollY > 100) {
                        nav?.classList.add("scrolled");
                    } else {
                        nav?.classList.remove("scrolled");
                    }
                    updateActiveSection();
                }

                function initMatrix() {
                    if (!matrixCanvas) return;
                    const ctx = matrixCanvas.getContext("2d");
                    matrixCanvas.width = window.innerWidth;
                    matrixCanvas.height = window.innerHeight;

                    const chars =
                        "01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン";
                    const columns = Math.floor(matrixCanvas.width / 20);
                    const drops = Array(columns).fill(1);

                    function draw() {
                        ctx.fillStyle = "rgba(2, 6, 23, 0.05)";
                        ctx.fillRect(
                            0,
                            0,
                            matrixCanvas.width,
                            matrixCanvas.height,
                        );
                        ctx.fillStyle = "#22C55E";
                        ctx.font = "14px monospace";

                        for (let i = 0; i < drops.length; i++) {
                            const char =
                                chars[Math.floor(Math.random() * chars.length)];
                            ctx.fillText(char, i * 20, drops[i] * 20);
                            if (
                                drops[i] * 20 > matrixCanvas.height &&
                                Math.random() > 0.975
                            ) {
                                drops[i] = 0;
                            }
                            drops[i]++;
                        }
                    }

                    const matrixInterval = setInterval(draw, 50);

                    window.addEventListener("resize", () => {
                        matrixCanvas.width = window.innerWidth;
                        matrixCanvas.height = window.innerHeight;
                    });

                    const mediaQuery = window.matchMedia(
                        "(prefers-reduced-motion: reduce)",
                    );
                    if (mediaQuery.matches) {
                        clearInterval(matrixInterval);
                        ctx.clearRect(
                            0,
                            0,
                            matrixCanvas.width,
                            matrixCanvas.height,
                        );
                    }
                }

                function toggleMobileMenu() {
                    hamburger?.classList.toggle("active");
                    mobileMenu?.classList.toggle("translate-x-full");
                    mobileMenu?.classList.toggle("translate-x-0");
                    document.body.classList.toggle("menu-open");
                }

                function closeMobileMenu() {
                    hamburger?.classList.remove("active");
                    mobileMenu?.classList.remove("translate-x-0");
                    mobileMenu?.classList.add("translate-x-full");
                    document.body.classList.remove("menu-open");
                }

                function typeWriter(element, text, speed = 50) {
                    let i = 0;
                    element.textContent = "";
                    function type() {
                        if (i < text.length) {
                            element.textContent += text.charAt(i);
                            i++;
                            setTimeout(type, speed);
                        }
                    }
                    type();
                }

                window.addEventListener("scroll", handleNavScroll, {
                    passive: true,
                });
                handleNavScroll();
                if (matrixCanvas) {
                    initMatrix();
                }

                if (hamburger) {
                    hamburger.addEventListener("click", toggleMobileMenu);
                }

                document
                    .querySelectorAll(".nav-link-mobile")
                    .forEach((link) => {
                        link.addEventListener("click", closeMobileMenu);
                    });

                const backToTopBtn = document.getElementById("back-to-top");
                window.addEventListener("scroll", () => {
                    if (window.scrollY > 400) {
                        backToTopBtn?.classList.remove(
                            "opacity-0",
                            "invisible",
                            "translate-y-4",
                        );
                        backToTopBtn?.classList.add(
                            "opacity-100",
                            "visible",
                            "translate-y-0",
                        );
                    } else {
                        backToTopBtn?.classList.remove(
                            "opacity-100",
                            "visible",
                            "translate-y-0",
                        );
                        backToTopBtn?.classList.add(
                            "opacity-0",
                            "invisible",
                            "translate-y-4",
                        );
                    }
                });

                backToTopBtn?.addEventListener("click", () => {
                    window.scrollTo({ top: 0, behavior: "smooth" });
                    setTimeout(() => backToTopBtn?.blur(), 100);
                });

                const typewriterElement = document.querySelector(".typewriter");
                if (typewriterElement) {
                    const text = typewriterElement.getAttribute("data-text");
                    setTimeout(
                        () => typeWriter(typewriterElement, text, 60),
                        500,
                    );
                }

                const yearEl = document.getElementById("year");
                if (yearEl)
                    yearEl.textContent = new Date().getFullYear().toString();

                const roles = [
                    "CTF Reports",
                    "Bug Bounty Research",
                    "Personal Projects",
                ];
                const roleElement = document.getElementById("role-rotate");
                let roleIndex = 0;
                let charIndex = 0;
                let isDeleting = false;
                let roleText = "";

                function typeRole() {
                    if (!roleElement) return;
                    const currentRole = roles[roleIndex];

                    if (!isDeleting) {
                        roleText = currentRole.substring(0, charIndex + 1);
                        charIndex++;
                        if (charIndex > currentRole.length) {
                            isDeleting = true;
                            setTimeout(typeRole, 2000);
                            return;
                        }
                    } else {
                        roleText = currentRole.substring(0, charIndex - 1);
                        charIndex--;
                        if (charIndex < 0) {
                            isDeleting = false;
                            roleIndex = (roleIndex + 1) % roles.length;
                            setTimeout(typeRole, 500);
                            return;
                        }
                    }

                    roleElement.innerHTML =
                        roleText +
                        '<span class="cursor" aria-hidden="true">|</span>';
                    const speed = isDeleting ? 30 : 80;
                    setTimeout(typeRole, speed);
                }

                setTimeout(typeRole, 1500);
            });
        </script>
    </body>
</html>
