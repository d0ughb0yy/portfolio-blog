---
interface Props {
	title: string;
	description?: string;
	showHero?: boolean;
}

const { title, description = 'Security research blog - CTF writeups and bug bounty findings', showHero = false } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="description" content={description} />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="generator" content={Astro.generator} />
	<title>{title} | Tin Lučić - Blog</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
	<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap" rel="stylesheet" />

	<script async src="https://www.googletagmanager.com/gtag/js?id=G-EWDHWHP1BC"></script>
	<script>
		window.dataLayer = window.dataLayer || [];
		window.gtag = function gtag(){window.dataLayer.push(arguments);};
		gtag('js', new Date());
		gtag('config', 'G-EWDHWHP1BC');
	</script>
</head>
<body class="min-h-screen bg-background font-sans">
	<header class="fixed top-0 left-0 right-0 xl:top-4 xl:left-0 xl:right-0 z-50">
		<nav id="navbar" class="xl:max-w-6xl xl:mx-auto px-4 py-3 flex items-center justify-between bg-surface/80 border-b border-border/30 xl:rounded-2xl transition-all duration-300">
			<a href="/" class="text-xl font-bold text-primary hover:text-accent transition-colors cursor-pointer">
				TinL
			</a>

			<button id="mobile-menu-btn" class="xl:hidden text-text-muted hover:text-primary transition-colors" aria-label="Toggle menu">
			<svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
			</svg>
			<svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
			</svg>
		</button>

			<div id="nav-links" class="hidden xl:flex items-center gap-6 px-4">
				<div class="relative group py-1">
					<a href="/" class="nav-link relative z-10">Home</a>
					<span class="absolute bottom-0 left-0 w-full h-px bg-primary origin-left scale-x-0 transition-transform duration-300 ease-out group-hover:scale-x-100"></span>
				</div>
				<div class="relative group py-1">
					<a href="/ctf" class="nav-link relative z-10">CTF</a>
					<span class="absolute bottom-0 left-0 w-full h-px bg-primary origin-left scale-x-0 transition-transform duration-300 ease-out group-hover:scale-x-100"></span>
				</div>
				<div class="relative group py-1">
					<a href="/bugbounty" class="nav-link relative z-10">Bug Bounty</a>
					<span class="absolute bottom-0 left-0 w-full h-px bg-primary origin-left scale-x-0 transition-transform duration-300 ease-out group-hover:scale-x-100"></span>
				</div>
				<div class="relative group py-1">
					<a href="/projects" class="nav-link relative z-10">Projects</a>
					<span class="absolute bottom-0 left-0 w-full h-px bg-primary origin-left scale-x-0 transition-transform duration-300 ease-out group-hover:scale-x-100"></span>
				</div>
				<div class="relative group py-1">
					<a href="https://tinl-portfolio.netlify.app" target="_blank" rel="noopener noreferrer" class="nav-link relative z-10">Portfolio</a>
					<span class="absolute bottom-0 left-0 w-full h-px bg-primary origin-left scale-x-0 transition-transform duration-300 ease-out group-hover:scale-x-100"></span>
				</div>
			</div>
		</nav>

		<div id="mobile-menu" class="xl:hidden fixed right-0 top-0 bottom-0 w-64 bg-background/40 backdrop-blur-xl z-50 transform translate-x-full transition-transform duration-300 ease-out">
			<button id="mobile-menu-close" type="button" class="absolute top-4 right-4 text-text-muted hover:text-primary transition-colors" aria-label="Close menu">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
				</svg>
			</button>

			<div class="flex flex-col items-center pt-16 gap-2">
				<a href="/" class="nav-link-mobile">Home</a>
				<a href="/ctf" class="nav-link-mobile">CTF</a>
				<a href="/bugbounty" class="nav-link-mobile">Bug Bounty</a>
				<a href="/projects" class="nav-link-mobile">Projects</a>
				<a href="https://tinl-portfolio.netlify.app" target="_blank" rel="noopener noreferrer" class="nav-link-mobile">
					Portfolio
				</a>
			</div>
		</div>

		<div id="mobile-backdrop" class="hidden fixed inset-0 bg-background/80 backdrop-blur-sm z-40 xl:hidden opacity-0 transition-opacity duration-300"></div>
	</header>

	{showHero && (
		<section class="pt-32 pb-16 px-6">
			<div class="max-w-5xl mx-auto">
				<div class="relative">
					<div class="absolute -top-20 -left-20 w-72 h-72 bg-accent/10 rounded-full blur-3xl animate-float"></div>
					<div class="absolute -bottom-20 -right-20 w-72 h-72 bg-primary/10 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>

					<div class="relative z-10">
						<h1 class="font-mono text-5xl md:text-6xl font-bold mb-4 opacity-0 animate-fade-in-up">
							<span class="text-text-primary">Welcome to</span>
							<span class="gradient-text">the Blog</span>
						</h1>
						<p class="text-xl text-text-secondary max-w-2xl mb-8 opacity-0 animate-fade-in-up stagger-1">
							Here I post CTF writeups, bug bounty findings,
							security research and personal projects.
						</p>
						<div class="flex flex-wrap gap-4 opacity-0 animate-fade-in-up stagger-2">
							<a href="/ctf" class="px-6 py-3 bg-primary/10 border border-primary/30 rounded-lg text-primary hover:bg-primary/20 hover:border-primary/50 transition-all duration-300 hover:scale-105">
								CTF Writeups
							</a>
							<a href="/bugbounty" class="px-6 py-3 bg-accent/10 border border-accent/30 rounded-lg text-accent hover:bg-accent/20 hover:border-accent/50 transition-all duration-300 hover:scale-105">
								Bug Bounty
							</a>
							<a href="/projects" class="px-6 py-3 bg-surface border border-border rounded-lg text-text-secondary hover:text-text-primary hover:border-primary/30 transition-all duration-300 hover:scale-105">
								Projects
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>
	)}

	<main class={`${showHero ? '' : 'pt-24'} max-w-6xl w-full mx-auto px-4 md:px-6 py-8`}>
		<slot />
	</main>

	<footer class="border-t border-border/50 mt-16">
		<div class="max-w-6xl mx-auto px-6 py-8">
			<div class="flex flex-col md:flex-row items-center justify-between gap-6">
				<div class="text-center md:text-left">
					<p class="text-text-secondary text-sm mb-1">© 2026 Tin Lučić. All rights reserved.</p>
					<p class="text-text-muted text-xs">Bug bounty hunter & Security researcher</p>
				</div>
				<div class="flex items-center gap-4">
					<a href="mailto:tin.lucic172@gmail.com" class="social-icon" aria-label="Email">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
					</a>
					<a href="https://github.com/d0ughb0yy" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="GitHub">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					</a>
					<a href="https://linkedin.com/in/tin-lu%C4%8Di%C4%87-367953266/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
					</a>
					<a href="https://tinl-portfolio.netlify.app" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Portfolio">
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
					</a>
				</div>
			</div>
		</div>
</footer>

<button
  id="back-to-top"
  class="fixed bottom-6 right-6 z-40 w-12 h-12 bg-primary/10 border border-primary/40 rounded-full flex items-center justify-center text-primary hover:text-primary hover:border-primary/70 hover:bg-primary/20 hover:shadow-[0_0_20px_rgba(56,189,248,0.4)] transition-all duration-300 opacity-0 invisible transform translate-y-4"
  aria-label="Back to top"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
  </svg>
</button>

<dialog
  id="global-image-modal"
  class="backdrop:bg-black/90 p-0 border-0 bg-transparent"
>
  <img
    id="global-modal-image"
    src=""
    alt=""
    class="max-w-[90vw] max-h-[85vh] object-contain rounded-lg"
  />
  <button
    id="global-modal-close"
    class="absolute top-1 right-1 z-10 w-8 h-8 bg-surface/80 rounded-full flex items-center justify-center text-primary hover:text-primary hover:bg-surface transition-colors"
    aria-label="Close modal"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6l-12 12" />
    </svg>
  </button>
</dialog>

<script>
  const backToTopBtn = document.getElementById('back-to-top');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) {
      backToTopBtn?.classList.remove('opacity-0', 'invisible', 'translate-y-4');
      backToTopBtn?.classList.add('opacity-100', 'visible', 'translate-y-0');
    } else {
      backToTopBtn?.classList.remove('opacity-100', 'visible', 'translate-y-0');
      backToTopBtn?.classList.add('opacity-0', 'invisible', 'translate-y-4');
    }
  });
  
  backToTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
    setTimeout(() => backToTopBtn?.blur(), 100);
  });

  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const backdrop = document.getElementById('mobile-backdrop');
  const navbar = document.getElementById('navbar');

  const toggleMenu = () => {
    const isOpen = mobileMenu?.classList.contains('translate-x-full');

    if (isOpen) {
      mobileMenu?.classList.remove('translate-x-full');
      mobileMenu?.classList.add('translate-x-0');
      backdrop?.classList.remove('hidden');
      setTimeout(() => backdrop?.classList.add('opacity-100'), 10);
      menuIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    } else {
      closeMenu();
    }
  };

  const closeMenu = () => {
    mobileMenu?.classList.remove('translate-x-0');
    mobileMenu?.classList.add('translate-x-full');
    backdrop?.classList.remove('opacity-100');
    setTimeout(() => backdrop?.classList.add('hidden'), 300);
    menuIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    document.body.style.overflow = '';
  };

  menuBtn?.addEventListener('click', toggleMenu);
  backdrop?.addEventListener('click', closeMenu);
  document.getElementById('mobile-menu-close')?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    closeMenu();
  });

  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

		window.addEventListener('scroll', () => {
			const currentScroll = window.scrollY;
			if (currentScroll > 50) {
				navbar?.classList.add('bg-surface/90');
				navbar?.classList.remove('bg-surface/80');
			} else {
				navbar?.classList.remove('bg-surface/90');
				navbar?.classList.add('bg-surface/80');
			}
		});
	</script>
</body>
</html>

<style is:global>
	@import '../styles/global.css';

	.animate-gradient {
		background-size: 200% 200%;
		animation: gradient-shift 20s ease infinite;
	}

	@keyframes gradient-shift {
		0%, 100% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
	}

.nav-link {
  color: #ebe6e7;
  @apply hover:text-primary cursor-pointer transition-colors;
}

.nav-link-mobile {
  color: #ebe6e7;
  @apply hover:text-primary transition-colors py-3 cursor-pointer text-lg w-full text-center;
  transition: transform 0.15s ease-out, color 0.2s ease;
}

.nav-link-mobile:active {
  transform: scale(0.98);
}

.social-icon {
  @apply text-text-muted hover:text-primary transition-all duration-300 hover:scale-110;
}

dialog::backdrop {
  background: rgba(0, 0, 0, 0.9);
}

dialog[open] {
  animation: fadeIn 0.15s ease-out;
}

#global-image-modal[open] #global-modal-close {
  position: fixed !important;
  top: 1rem !important;
  right: 1rem !important;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
</style>