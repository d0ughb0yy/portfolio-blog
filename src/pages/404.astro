---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="flex flex-col items-center justify-center py-16">
    <h1 class="text-6xl font-bold text-accent mb-4">404</h1>
    <p class="text-2xl text-text-primary mb-2">Page Not Found</p>
    <p class="text-text-muted mb-8">The page you're looking for doesn't exist.</p>
    <a 
      href="/" 
      class="px-6 py-3 bg-primary text-background font-semibold rounded-lg hover:bg-accent transition-colors"
    >
      Go Home
    </a>
  </div>
</BaseLayout>