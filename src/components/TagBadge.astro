---
interface Props {
tag: string;
colored?: boolean;
}

const { tag, colored = false } = Astro.props;

const colors = [
'bg-[rgba(34,197,94,0.1)] text-primary border-[rgba(34,197,94,0.3)]',
'bg-[rgba(16,185,129,0.1)] text-emerald-400 border-[rgba(16,185,129,0.3)]',
'bg-[rgba(20,184,166,0.1)] text-teal-400 border-[rgba(20,184,166,0.3)]',
'bg-[rgba(6,182,212,0.1)] text-cyan-400 border-[rgba(6,182,212,0.3)]',
'bg-[rgba(59,130,246,0.1)] text-blue-400 border-[rgba(59,130,246,0.3)]',
'bg-[rgba(139,92,246,0.1)] text-violet-400 border-[rgba(139,92,246,0.3)]',
'bg-[rgba(168,85,247,0.1)] text-purple-400 border-[rgba(168,85,247,0.3)]',
'bg-[rgba(236,72,153,0.1)] text-pink-400 border-[rgba(236,72,153,0.3)]',
'bg-[rgba(249,115,22,0.1)] text-orange-400 border-[rgba(249,115,22,0.3)]',
'bg-[rgba(234,179,8,0.1)] text-yellow-400 border-[rgba(234,179,8,0.3)]',
];

const colorIndex = tag.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0) % colors.length;
const colorClass = colors[colorIndex];
const plainClass = 'bg-surface text-text-muted border-border';
---

{colored ? (
	<span class={`text-xs font-mono px-2 py-1 rounded border ${colorClass}`}>
	{tag}
	</span>
) : (
	<span class={`text-xs font-mono px-2 py-1 rounded border ${plainClass}`}>
	{tag}
	</span>
)}