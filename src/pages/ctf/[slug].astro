---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import PlatformBadge from '../../components/PlatformBadge.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import TagBadge from '../../components/TagBadge.astro';
import ClickableImage from '../../components/ClickableImage.astro';

export async function getStaticPaths() {
  const posts = await getCollection('ctf', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const components = {
  img: ClickableImage,
};

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
<article class="glass-strong rounded-2xl p-8">
	<header class="mb-8">
      <div class="flex items-center gap-2 mb-4">
        <PlatformBadge platform={post.data.ctfPlatform} />
        <DifficultyBadge difficulty={post.data.difficulty} />
      </div>
      <h1 class="text-3xl font-bold text-text-primary mb-4">{post.data.title}</h1>
      <time class="text-text-muted text-sm" datetime={post.data.pubDate.toISOString()}>
        {formattedDate}
      </time>
    </header>

<div class="prose max-w-none">
  <Content components={components} />
    </div>

    {post.data.tags.length > 0 && (
      <footer class="mt-8 pt-8 border-t border-border">
        <div class="flex flex-wrap gap-2">
          {post.data.tags.slice(0, 3).map((tag) => <TagBadge tag={tag} />)}
        </div>
      </footer>
    )}

<div class="mt-8">
	<a href="/ctf" class="text-primary hover:underline text-sm">← Back to CTF Writeups</a>
</div>
  </article>
</BaseLayout>